		"@tauri-apps/plugin-store": "~2.4.4",
		"@tauri-apps/plugin-updater": "~2.10.1",
		"@tauri-apps/plugin-window-state": "=2.2.3",
		"@toolpad/core": "^0.16.0",
		"fuse.js": "^7.5.0",
		"html-react-parser": "^5.2.17",
		"i18next": "^26.3.6",
